# Скопіюй цей файл як .env і заповни значеннями.
# .env у git НЕ комітиться (див. .gitignore).

# === Telegram ===
# Отримай у @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# === Юрист-партнер: Дмитро Глушко ===
LAWYER_NAME=Дмитро Глушко
LAWYER_TELEGRAM=@dmytrolawua
LAWYER_PHONE=
LAWYER_SPECIALIZATION=
# Числовий Telegram ID юриста — для прямого push заявок з форми консультації.
# Якщо порожньо — заявка тільки зберігається в БД, юриста повідомляємо вручну.
LAWYER_TELEGRAM_ID=

# === Налаштування ===
# Шлях до SQLite-БД
DATABASE_URL=sqlite:///data/pravohelp.db

# Рівень логування: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Адміни бота — Telegram user_id через кому (для команд /admin_*)
ADMIN_TELEGRAM_IDS=

# Максимальна кількість сценаріїв на користувача за годину (rate-limit)
MAX_SCENARIOS_PER_HOUR=5
